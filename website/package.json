{
  "name": "rfwhisper-website",
  "version": "0.1.0",
  "private": true,
  "description": "Documentation site for RFWhisper — real-time AI denoising for amateur radio.",
  "license": "GPL-3.0-or-later",
  "engines": {
    "node": ">=18.17"
  },
  "overrides": {
    "webpack": "5.95.0"
  },
  "scripts": {
    "prestart": "npm run sync:all",
    "prebuild": "npm run sync:all",
    "sync:all": "node scripts/sync-all.mjs",
    "sync:readme": "node scripts/sync-readme.mjs",
    "sync:roadmap": "node scripts/sync-roadmap.mjs",
    "sync:grc": "node scripts/grc-to-mermaid.mjs",
    "sync:api": "node scripts/extract-api-docs.mjs",
    "docusaurus": "docusaurus",
    "start": "docusaurus start --port 3000 --host 0.0.0.0",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "docs:version": "docusaurus docs:version",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx src/"
  },
  "dependencies": {
    "@docusaurus/core": "^3.6.3",
    "@docusaurus/preset-classic": "^3.6.3",
    "@docusaurus/theme-mermaid": "^3.6.3",
    "@docusaurus/plugin-ideal-image": "^3.6.3",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.1.1",
    "prism-react-renderer": "^2.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.6.3",
    "@docusaurus/tsconfig": "^3.6.3",
    "@docusaurus/types": "^3.6.3",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.1",
    "gray-matter": "^4.0.3",
    "typescript": "~5.5.4"
  },
  "browserslist": {
    "production": [">0.5%", "not dead", "not op_mini all"],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  }
}
